# Copy to `.env` and fill in values. Never commit `.env`.
#
# Secrets and local tokens also live under gitignored paths:
#   data/          — DuckDB, crawl/mail caches, artifacts
#   data/secrets/  — OAuth tokens and other credential files (create as needed)

# Required for LLM modules (Sprint 1 stories S1.3+)
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Provider: openai (default) | local_llama (placeholder only in Sprint 1)
# CRAWLEY_LLM_PROVIDER=openai

# Optional: override bind (defaults are 127.0.0.1:8000)
# CRAWLEY_HOST=127.0.0.1
# CRAWLEY_PORT=8000

# Google OAuth (Sprint 1 story S1.5 — Gmail read-only)
# Use Desktop / installed-app credentials; enable Gmail API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Tokens are written to data/secrets/gmail_token.json (gitignored)
# Local http://127.0.0.1 OAuth is allowed automatically by the app (oauthlib).
