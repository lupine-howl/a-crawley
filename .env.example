# Copy to `.env` and fill in values. Never commit `.env`.
#
# Secrets and local tokens also live under gitignored paths:
#   data/          — DuckDB, crawl/mail caches, artifacts
#   data/secrets/  — OAuth tokens and other credential files (create as needed)

# Required for LLM modules (Sprint 1 stories S1.3+)
OPENAI_API_KEY=

# Optional: override bind (defaults are 127.0.0.1:8000)
# CRAWLEY_HOST=127.0.0.1
# CRAWLEY_PORT=8000

# Google OAuth (Sprint 1 story S1.5 — Gmail read-only)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
