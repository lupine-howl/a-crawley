# Copy to `.env` and fill in values. Never commit `.env`.
#
# Secrets and local tokens also live under gitignored paths:
#   data/          — DuckDB, crawl/mail caches, artifacts
#   data/secrets/  — OAuth tokens and other credential files (create as needed)

# Required for OpenAI path (or configure in Settings)
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Provider: openai (default) | local_llama (Ollama HTTP — configure URL/model in Settings)
# CRAWLEY_LLM_PROVIDER=openai
# CRAWLEY_LOCAL_LLM_URL=http://127.0.0.1:11434
# CRAWLEY_LOCAL_LLM_MODEL=llama3.2

# Optional: override bind (default 127.0.0.1:8000). Non-empty CRAWLEY_HOST overrides Settings → LAN toggle.
# CRAWLEY_HOST=127.0.0.1
# CRAWLEY_PORT=8000
# For phone-on-LAN testing only (trusted network; no auth):
# CRAWLEY_HOST=0.0.0.0

# Dev: auto-reload when Python/templates under src/crawley change (incl. after git pull)
# CRAWLEY_RELOAD=1

# Sender Inbox PoC hard cap (default 20). Restart after changing.
# CRAWLEY_SENDER_INBOX_CAP=20

# ASX desk PoC company cap (default 20). Restart after changing.
# CRAWLEY_ASX_POC_CAP=20

# Google OAuth (Gmail + Calendar read-only by default; optional calendar.events for insert)
# Use Desktop / installed-app credentials; enable Gmail API and Google Calendar API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Tokens: data/secrets/google_token.json (legacy gmail_token.json kept in sync)
# Local http://127.0.0.1 OAuth is allowed automatically by the app (oauthlib).
