{
  "name": "@crawley/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Crawley product host — Phone Preview + portable @crawley/* packs",
  "scripts": {
    "dev": "concurrently -k -n api,ui -c cyan,magenta \"npm run dev:api\" \"vite\"",
    "dev:api": "uv run --directory ../../services/crawley python -m crawley",
    "dev:ui": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@crawley/asx": "*",
    "@crawley/inbox": "*",
    "@crawley/settings": "*",
    "@phone-preview/core": "^0.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
