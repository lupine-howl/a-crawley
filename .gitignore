# Crawley local secrets and runtime data (do not commit)
.env
.env.*
!.env.example
!services/crawley/.env.example

# Runtime data plane (DuckDB, caches, OAuth tokens, crawl artifacts)
services/crawley/data/*
!services/crawley/data/.gitkeep
# Legacy paths (pre services/ layout) — ignore leftovers on old checkouts
/data/*
apps/crawley/analytics/

# Python / tooling
.venv/
services/crawley/.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
/build/

# Node (npm workspaces)
node_modules/
apps/*/dist/
apps/*/node_modules/
packages/*/node_modules/
packages/*/dist/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
