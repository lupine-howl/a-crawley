# Crawley local secrets and runtime data (do not commit)
.env
.env.*
!.env.example
!apps/crawley/analytics/.env.example

# Runtime data plane (DuckDB, caches, OAuth tokens, crawl artifacts)
# Lives under the analytics uv project (not monorepo root).
apps/crawley/analytics/data/*
!apps/crawley/analytics/data/.gitkeep
# Legacy root path (pre nest) — ignore if leftover on old checkouts
/data/*

# Python / tooling
.venv/
apps/crawley/analytics/.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
/build/

# Node (npm workspaces)
node_modules/
apps/*/dist/
apps/*/node_modules/
packages/*/node_modules/
packages/*/dist/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
